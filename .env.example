# Application
ENVIRONMENT=development
LOG_LEVEL=info
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://gateway:gateway@localhost:5432/gateway

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth / JWT (service accounts)
JWKS_URL=http://localhost:8080/.well-known/jwks.json

# Portal integration — opaque token validation
# NOTE: http://localhost is for local development only. Production MUST use https://.
PORTAL_URL=http://localhost:8001
# Must match GATEWAY_PORTAL_SHARED_SECRET in the portal's .env
PORTAL_SHARED_SECRET=dev-shared-secret-change-me-in-production
PORTAL_TOKEN_CACHE_TTL=60
# Set false ONLY for local development on loopback. Default is true.
REQUIRE_HTTPS=false
